# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/golden_store"

# Use a long random value in production to sign customer session cookies.
AUTH_SECRET="replace-with-a-long-random-secret"

# Google Cloud OAuth web application credentials.
# Add http://localhost:3000/api/auth/google/callback (and the production URL)
# as an Authorized redirect URI in Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
